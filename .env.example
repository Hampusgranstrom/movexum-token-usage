# --- Anthropic (AI-assistenten) ---------------------------------------------

# Claude API-nyckel. Skapas på: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Supabase ---------------------------------------------------------------

# Projekt-URL från Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=

# Service role key -- server-only, lagg ALDRIG i frontend eller i commits.
# Dashboard -> Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# Anon key -- anvands i browsern for Supabase Auth (inloggning).
# Dashboard -> Project Settings -> API -> Project API keys -> anon
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Domain split (multi-surface) -------------------------------------------
#
# Produktionsrekommendation: dela admin-ytan och det publika intaget pa tva
# subdomaner. Middleware harskar over hostname och redirectar tva-vags:
#   - Publika foragningar (/m/<slug>, /api/chat, /api/modules) trycks till
#     PUBLIC_HOST.
#   - Admin-routes (/admin, /leads, /login, /accept-invite, /api/admin) trycks
#     till ADMIN_HOST.
# Om antingen variabel saknas kor appen i "combined mode" (allt pa samma host
# -- bra for localhost + preview).
#
# Exempel produktion:
#   PUBLIC_HOST=startupkompassen.se
#   ADMIN_HOST=admin.startupkompassen.se
PUBLIC_HOST=
ADMIN_HOST=

# Publik bas-URL for generiska fallbacks (t.ex. invite-mail redirectTo nar
# ADMIN_HOST saknas). NEXT_PUBLIC_SITE_URL exponeras i weblasaren; SITE_URL
# ar server-only och prioriteras for invite-redirects. Satt minst en av dem.
SITE_URL=
NEXT_PUBLIC_SITE_URL=

# --- Storage (skapas automatiskt vid forsta logo-uppladdning) ---------------
# En publik bucket med namnet "brand" skapas av /api/admin/brand nar
# superadmin laddar upp logotypen forsta gangen. Behovs inte satta manuellt.

# --- Founder inbox (transaktionellt mail efter inskick) ----------------------
# Optionalt: satts for att skicka summering + nasta steg till founders.
# Exempel:
#   RESEND_API_KEY=re_xxx
#   FOUNDER_INBOX_FROM=Movexum <founders@startupkompassen.se>
RESEND_API_KEY=
FOUNDER_INBOX_FROM=
