# OpenAI Admin API key for the Usage API.
# Must be an ADMIN key (starts with sk-admin-...), not a regular project key.
# Create one at: https://platform.openai.com/settings/organization/admin-keys
# Leave blank to run the dashboard with mock data.
OPENAI_ADMIN_KEY=

# Optional: default grid for CO2 conversion. One of: "global" | "sweden".
# Defaults to "global".
DEFAULT_GRID=global
