# --- OpenAI -----------------------------------------------------------------

# OpenAI Admin API key. Måste vara en ADMIN-nyckel (sk-admin-...),
# inte en vanlig projekt-nyckel. Skapas i OpenAI Platform under:
#   Settings → Organization → Admin keys
# Ge den minst "api.usage.read" (och gärna "api.costs.read").
OPENAI_ADMIN_KEY=

# --- Supabase ---------------------------------------------------------------

# Projekt-URL från Supabase Dashboard → Project Settings → API
SUPABASE_URL=

# Service role key — server-only, lägg ALDRIG i frontend eller i commits.
# Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / sync ------------------------------------------------------------

# Delad hemlighet mellan /api/sync och den som triggar den
# (GitHub Actions-workflow, Vercel Cron, osv). Generera med:
#   openssl rand -hex 32
CRON_SECRET=

# --- Valfritt ---------------------------------------------------------------

# Default elnät för CO2-konvertering. "global" eller "sweden". Default: global
DEFAULT_GRID=global
