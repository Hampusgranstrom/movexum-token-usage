# --- Anthropic (AI-assistenten) ---------------------------------------------

# Claude API-nyckel. Skapas på: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Supabase ---------------------------------------------------------------

# Projekt-URL från Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=

# Service role key -- server-only, lagg ALDRIG i frontend eller i commits.
# Dashboard -> Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# Anon key -- anvands i browsern for Supabase Auth (inloggning).
# Dashboard -> Project Settings -> API -> Project API keys -> anon
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App ---------------------------------------------------------------------

# Publik bas-URL till appen. Anvands som redirectTo nar superadmin bjuder in
# nya anvandare via Supabase invite. Valfri -- om den inte satts anvands
# request-originen i stallet.
# Exempel: https://startupkompass.movexum.se
NEXT_PUBLIC_SITE_URL=

# --- Storage (skapas automatiskt vid forsta logo-uppladdning) ---------------
# En publik bucket med namnet "brand" skapas av /api/admin/brand nar
# superadmin laddar upp logotypen forsta gangen. Behovs inte satta manuellt.
