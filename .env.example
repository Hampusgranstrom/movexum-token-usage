# --- OpenAI (för chatten på /chat) -----------------------------------------

# REGULJÄR projektnyckel (sk-... eller sk-proj-...). Skapas på:
#   https://platform.openai.com/api-keys
# Används av /api/chat för att anropa Chat Completions. Krävs för att
# chatten och därmed token-loggningen ska fungera.
OPENAI_API_KEY=

# ADMIN-nyckel (sk-admin-...). VALFRI. Används bara som fallback för
# /api/usage om Supabase-events-tabellen är tom och orgen ändå har
# Platform API-trafik. Kan lämnas tom för ChatGPT Business-användare.
# Skapas på:
#   https://platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=

# --- Supabase ---------------------------------------------------------------

# Projekt-URL från Supabase Dashboard → Project Settings → API
SUPABASE_URL=

# Service role key — server-only, lägg ALDRIG i frontend eller i commits.
# Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / sync ------------------------------------------------------------

# Valfri. Används bara av /api/sync och /api/debug (admin-fallback-pathen).
# Generera med: openssl rand -hex 32
CRON_SECRET=

# --- Valfritt ---------------------------------------------------------------

# Default elnät för CO2-konvertering. "global" eller "sweden". Default: global
DEFAULT_GRID=global
